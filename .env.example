# Movie Discovery — API Keys
# Copy this file to .env and fill in your actual keys.
# Never commit .env to version control.

# Reqres — https://app.reqres.in/api-keys (free)
REQRES_API_KEY=YOUR_REQRES_KEY

# TMDB — https://www.themoviedb.org/settings/api (free, use "API Key v3 auth")
TMDB_API_KEY=YOUR_TMDB_KEY

# OMDB — https://www.omdbapi.com/apikey.aspx (free, used as TMDB fallback)
OMDB_API_KEY=YOUR_OMDB_KEY
