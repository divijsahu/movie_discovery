# Example environment variables for the Flutter App Template
# Copy this file to .env and update with your actual values

# API Configuration
API_BASE_URL=https://api.yourapp.com
API_VERSION=v1

# App Configuration
APP_NAME=Your App Name
DEBUG_MODE=true
ENABLE_LOGGING=true

# Feature Flags
ENABLE_ANALYTICS=false
ENABLE_CRASH_REPORTING=false
ENABLE_PUSH_NOTIFICATIONS=false

# Authentication (if using Firebase or similar)
# FIREBASE_API_KEY=your_firebase_api_key
# FIREBASE_APP_ID=your_firebase_app_id
# FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# Third-party Services
# GOOGLE_MAPS_API_KEY=your_google_maps_key
# STRIPE_PUBLISHABLE_KEY=your_stripe_key

# Storage
# AWS_S3_BUCKET=your_bucket_name
# AWS_REGION=us-east-1

# Contact Information
CONTACT_EMAIL=support@yourapp.com
SUPPORT_PHONE=+1234567890

# Social Media
FACEBOOK_PAGE_ID=your_facebook_page
INSTAGRAM_USERNAME=your_instagram
TWITTER_HANDLE=your_twitter

# Note: Never commit the actual .env file to version control!
# Add .env to your .gitignore file
